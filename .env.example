# Copy to `.env` in the project root (never commit `.env`).
# `server.js` loads it via dotenv.

# --- Google Gemini (default) ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
LLM_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_KNOWLEDGE_DIR=knowledge
# Optional: single file overrides folder scan (path under project root).
# GEMINI_KNOWLEDGE_MD_PATH=knowledge/entanglement-project-context.md

# --- Optional: OpenAI-compatible proxy (LiteLLM, OpenAI, etc.) ---
# LLM_PROVIDER=openai
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=
# Use a model id your proxy allows (Duke LiteLLM often uses display names like "GPT 4.1").
# LLM_DEFAULT_MODEL=GPT 4.1
# If LLM_DEFAULT_MODEL was left as a Gemini id, the server maps requests to this instead:
# LLM_OPENAI_FALLBACK_MODEL=GPT 4.1
